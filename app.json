{
  "expo": {
    "name": "Owen",
    "slug": "owen-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/owen_icon_white.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f766e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.owen.app",
      "requiresFullScreen": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#6366f1"
      },
      "package": "com.owen.app",
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {},
    "plugins": [
      "expo-font",
      [
        "expo-barcode-scanner",
        {
          "cameraPermission": "Allow Owen to access your camera to scan food barcodes."
        }
      ],
      "expo-sqlite"
    ],
    "sdkVersion": "54.0.0",
    "extra": {
      "edamamFoodAppId": "YOUR_EDAMAM_FOOD_APP_ID",
      "edamamFoodAppKey": "YOUR_EDAMAM_FOOD_APP_KEY"
    }
  }
}
